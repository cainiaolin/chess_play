{
  "pages": [
    "pages/game/game",
    "pages/spectate/spectate",
    "pages/settings/settings"
  ],
  "window": {
    "backgroundTextStyle": "light",
    "navigationBarBackgroundColor": "#fff",
    "navigationBarTitleText": "中国象棋对决",
    "navigationBarTextStyle": "black"
  },
  "tabBar": {
    "color": "#7A7E83",
    "selectedColor": "#3cc51f",
    "borderStyle": "black",
    "backgroundColor": "#ffffff",
    "list": [
      {
        "pagePath": "pages/game/game",
        "iconPath": "images/icon-game.png",
        "selectedIconPath": "images/icon-game-active.png",
        "text": "对弈"
      },
      {
        "pagePath": "pages/spectate/spectate",
        "iconPath": "images/icon-spectate.png",
        "selectedIconPath": "images/icon-spectate-active.png",
        "text": "观战"
      },
      {
        "pagePath": "pages/settings/settings",
        "iconPath": "images/icon-settings.png",
        "selectedIconPath": "images/icon-settings-active.png",
        "text": "设置"
      }
    ]
  },
  "style": "v2",
  "sitemapLocation": "sitemap.json",
  "permission": {
    "scope.userLocation": {
      "desc": "你的位置信息将用于小程序位置接口的效果展示"
    }
  },
  "usingComponents": {
    "chess-board": "/components/chess-board/chess-board",
    "control-panel": "/components/control-panel/control-panel"
  }
}
