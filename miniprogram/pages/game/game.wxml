<!--游戏页面-->
<view class="game-page">
  <!-- 游戏状态栏 -->
  <view class="status-bar">
    <view class="status-info">
      <text class="status-text" wx:if="{{gameStatus === 'ready'}}">准备中</text>
      <text class="status-text status-playing" wx:if="{{gameStatus === 'playing'}}">
        {{gameState.currentPlayer === 'red' ? '红方回合' : '黑方回合'}}
      </text>
      <text class="status-text status-ended" wx:if="{{gameStatus === 'ended'}}">游戏结束</text>
    </view>
    <view class="game-info" wx:if="{{gameState}}">
      <text class="info-text">步数：{{gameState.moveHistory.length}}</text>
    </view>
  </view>

  <!-- 加载中 -->
  <view class="loading-container" wx:if="{{isLoading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 错误信息 -->
  <view class="error-container" wx:if="{{errorMessage}}">
    <text class="error-text">{{errorMessage}}</text>
    <button class="retry-btn" bindtap="createNewGame">重新创建游戏</button>
  </view>

  <!-- 游戏区域 -->
  <view class="game-container" wx:if="{{gameState && !isLoading}}">
    <!-- 棋盘组件 -->
    <chess-board
      fen="{{gameState.fen}}"
      currentPlayer="{{gameState.currentPlayer}}"
      selectedPiece="{{selectedPiece}}"
      validMoves="{{validMoves}}"
      lastMove="{{lastMove}}"
      disabled="{{gameStatus !== 'playing' || gameState.currentPlayer !== 'red'}}"
      bind:boardclick="handleBoardClick"
    />

    <!-- 控制面板 -->
    <control-panel
      gameStatus="{{gameStatus}}"
      currentPlayer="{{gameState.currentPlayer}}"
      bind:undo="handleUndo"
      bind:hint="handleHint"
      bind:restart="handleRestart"
      bind:back="handleBack"
    />
  </view>

  <!-- 游戏结果 -->
  <view class="game-result" wx:if="{{gameStatus === 'ended'}}">
    <view class="result-content">
      <text class="result-title">
        <text wx:if="{{gameState.status === 'red_win'}}">恭喜获胜！</text>
        <text wx:if="{{gameState.status === 'black_win'}}">遗憾落败</text>
        <text wx:if="{{gameState.status === 'draw'}}">和棋</text>
      </text>
      <view class="result-actions">
        <button class="btn btn-primary" bindtap="createNewGame">再来一局</button>
        <button class="btn btn-secondary" bindtap="handleBack">返回</button>
      </view>
    </view>
  </view>
</view>
