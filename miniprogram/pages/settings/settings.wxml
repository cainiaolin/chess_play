<view class="settings-page">
  <!-- API 密钥配置 -->
  <view class="settings-section">
    <view class="section-header">
      <text class="section-title">🔑 API 密钥配置</text>
      <text class="section-subtitle">配置 AI 服务的 API 密钥以启用相应功能</text>
    </view>

    <view class="api-key-list">
      <view class="api-key-item">
        <view class="key-header">
          <view class="key-info">
            <text class="key-emoji">🤖</text>
            <view class="key-details">
              <text class="key-name">OpenAI API Key</text>
              <text class="key-desc">用于 GPT-4 模型</text>
            </view>
          </view>
          <view class="key-status {{apiKeyStatus.openai ? 'configured' : ''}}">
            <text>{{apiKeyStatus.openai ? '已配置' : '未配置'}}</text>
          </view>
        </view>
        <input
          class="key-input"
          placeholder="sk-..."
          value="{{apiKeys.openai}}"
          password="{{!showKeys.openai}}"
          bindinput="onOpenAIKeyInput"
        />
        <view class="key-actions">
          <button class="action-btn" bind:tap="onToggleShowKey" data-provider="openai">
            {{showKeys.openai ? '隐藏' : '显示'}}
          </button>
          <button class="action-btn primary" bind:tap="onSaveKey" data-provider="openai">
            保存
          </button>
        </view>
      </view>

      <view class="api-key-item">
        <view class="key-header">
          <view class="key-info">
            <text class="key-emoji">🧠</text>
            <view class="key-details">
              <text class="key-name">DeepSeek API Key</text>
              <text class="key-desc">用于 DeepSeek 模型</text>
            </view>
          </view>
          <view class="key-status {{apiKeyStatus.deepseek ? 'configured' : ''}}">
            <text>{{apiKeyStatus.deepseek ? '已配置' : '未配置'}}</text>
          </view>
        </view>
        <input
          class="key-input"
          placeholder="sk-..."
          value="{{apiKeys.deepseek}}"
          password="{{!showKeys.deepseek}}"
          bindinput="onDeepSeekKeyInput"
        />
        <view class="key-actions">
          <button class="action-btn" bind:tap="onToggleShowKey" data-provider="deepseek">
            {{showKeys.deepseek ? '隐藏' : '显示'}}
          </button>
          <button class="action-btn primary" bind:tap="onSaveKey" data-provider="deepseek">
            保存
          </button>
        </view>
      </view>

      <view class="api-key-item">
        <view class="key-header">
          <view class="key-info">
            <text class="key-emoji">🐼</text>
            <view class="key-details">
              <text class="key-name">文心一言 Access Token</text>
              <text class="key-desc">用于百度文心一言模型</text>
            </view>
          </view>
          <view class="key-status {{apiKeyStatus.qiwens ? 'configured' : ''}}">
            <text>{{apiKeyStatus.qiwens ? '已配置' : '未配置'}}</text>
          </view>
        </view>
        <input
          class="key-input"
          placeholder="access_token..."
          value="{{apiKeys.qiwens}}"
          password="{{!showKeys.qiwens}}"
          bindinput="onQiwensKeyInput"
        />
        <view class="key-actions">
          <button class="action-btn" bind:tap="onToggleShowKey" data-provider="qiwens">
            {{showKeys.qiwens ? '隐藏' : '显示'}}
          </button>
          <button class="action-btn primary" bind:tap="onSaveKey" data-provider="qiwens">
            保存
          </button>
        </view>
      </view>
    </view>
  </view>

  <!-- 服务器设置 -->
  <view class="settings-section">
    <view class="section-header">
      <text class="section-title">🖥️ 服务器设置</text>
    </view>

    <view class="setting-item">
      <text class="setting-label">服务器地址</text>
      <input
        class="setting-input"
        placeholder="http://localhost:3000"
        value="{{serverUrl}}"
        bindinput="onServerUrlInput"
      />
    </view>

    <button class="test-btn" bind:tap="onTestConnection" disabled="{{isTesting}}">
      {{isTesting ? '测试中...' : '测试连接'}}
    </button>
  </view>

  <!-- 游戏设置 -->
  <view class="settings-section">
    <view class="section-header">
      <text class="section-title">🎮 游戏设置</text>
    </view>

    <view class="setting-item switch-item">
      <view class="setting-info">
        <text class="setting-label">启用音效</text>
        <text class="setting-desc">走棋时的音效反馈</text>
      </view>
      <switch checked="{{soundEnabled}}" bindchange="onSoundChange" color="#8B4513" />
    </view>

    <view class="setting-item switch-item">
      <view class="setting-info">
        <text class="setting-label">震动反馈</text>
        <text class="setting-desc">走棋时的震动反馈</text>
      </view>
      <switch checked="{{vibrateEnabled}}" bindchange="onVibrateChange" color="#8B4513" />
    </view>
  </view>

  <!-- 关于 -->
  <view class="settings-section">
    <view class="section-header">
      <text class="section-title">ℹ️ 关于</text>
    </view>

    <view class="about-info">
      <view class="about-item">
        <text class="about-label">应用名称</text>
        <text class="about-value">中国象棋 AI 对决</text>
      </view>
      <view class="about-item">
        <text class="about-label">版本</text>
        <text class="about-value">1.0.0</text>
      </view>
    </view>
  </view>

  <!-- 底部按钮 -->
  <view class="footer-actions">
    <button class="footer-btn danger" bind:tap="onClearAllData">
      清除所有数据
    </button>
  </view>
</view>
