<view class="spectate-page">
  <!-- 模型选择区域 -->
  <view class="setup-section" wx:if="{{!gameStarted}}">
    <view class="setup-card">
      <text class="setup-title">选择对战双方</text>

      <view class="model-selection">
        <view class="selection-column">
          <text class="column-title red-title">🔴 红方 AI</text>
          <picker class="model-picker" range="{{aiModels}}" value="{{redModelIndex}}" bindchange="onRedModelChange">
            <view class="picker-value">{{aiModels[redModelIndex]}}</view>
          </picker>
        </view>

        <view class="versus-badge">
          <text class="versus-text">VS</text>
        </view>

        <view class="selection-column">
          <text class="column-title black-title">⚫ 黑方 AI</text>
          <picker class="model-picker" range="{{aiModels}}" value="{{blackModelIndex}}" bindchange="onBlackModelChange">
            <view class="picker-value">{{aiModels[blackModelIndex]}}</view>
          </picker>
        </view>
      </view>

      <view class="speed-section">
        <text class="speed-title">对弈速度</text>
        <view class="speed-options">
          <view
            class="speed-option {{speed === 'slow' ? 'active' : ''}}"
            bind:tap="onSpeedSelect"
            data-speed="slow"
          >
            <text class="speed-emoji">🐢</text>
            <text class="speed-label">慢速</text>
          </view>
          <view
            class="speed-option {{speed === 'normal' ? 'active' : ''}}"
            bind:tap="onSpeedSelect"
            data-speed="normal"
          >
            <text class="speed-emoji">🚶</text>
            <text class="speed-label">正常</text>
          </view>
          <view
            class="speed-option {{speed === 'fast' ? 'active' : ''}}"
            bind:tap="onSpeedSelect"
            data-speed="fast"
          >
            <text class="speed-emoji">🐇</text>
            <text class="speed-label">快速</text>
          </view>
        </view>
      </view>

      <button class="start-btn" bind:tap="onStartGame" disabled="{{isStarting}}">
        {{isStarting ? '准备中...' : '🎮 开始观战'}}
      </button>
    </view>
  </view>

  <!-- 观战区域 -->
  <view class="spectate-section" wx:if="{{gameStarted}}">
    <view class="match-header">
      <view class="player-info red-player">
        <text class="player-emoji">🔴</text>
        <text class="player-name">{{aiModels[redModelIndex]}}</text>
      </view>

      <view class="match-score">
        <text class="score-label">第 {{moveCount}} 步</text>
      </view>

      <view class="player-info black-player">
        <text class="player-name">{{aiModels[blackModelIndex]}}</text>
        <text class="player-emoji">⚫</text>
      </view>
    </view>

    <view class="status-container">
      <game-status
        turn="{{gameState.turn}}"
        status="{{gameState.status}}"
        lastMove="{{gameState.lastMove}}"
        moveCount="{{moveCount}}"
      />
    </view>

    <view class="board-container">
      <chess-board
        gameState="{{gameState}}"
        disabled="{{true}}"
      />
    </view>

    <view class="spectate-controls">
      <button class="control-btn {{isPaused ? 'warning' : ''}}" bind:tap="onTogglePause">
        {{isPaused ? '▶️ 继续' : '⏸️ 暂停'}}
      </button>
      <button class="control-btn" bind:tap="onRestart">
        🔄 重新开始
      </button>
      <button class="control-btn" bind:tap="onExit">
        🚪 退出观战
      </button>
    </view>

    <view class="thinking-indicator" wx:if="{{isThinking && !isPaused}}">
      <view class="thinking-dots">
        <text class="dot">●</text>
        <text class="dot">●</text>
        <text class="dot">●</text>
      </view>
      <text class="thinking-text">{{currentTurnModel}} 思考中...</text>
    </view>
  </view>
</view>
