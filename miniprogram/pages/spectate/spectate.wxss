.spectate-page {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

/* 设置区域 */
.setup-section {
  padding: 40rpx;
}

.setup-card {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.setup-title {
  display: block;
  text-align: center;
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 40rpx;
}

.model-selection {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
  margin-bottom: 40rpx;
}

.selection-column {
  flex: 1;
}

.column-title {
  display: block;
  text-align: center;
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.red-title {
  color: #e74c3c;
}

.black-title {
  color: #2c3e50;
}

.model-picker {
  padding: 20rpx;
  background-color: #f8f9fa;
  border-radius: 12rpx;
  border: 1rpx solid #e0e0e0;
}

.picker-value {
  text-align: center;
  font-size: 26rpx;
  color: #333;
}

.versus-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  background: linear-gradient(135deg, #e74c3c, #2c3e50);
  border-radius: 50%;
  flex-shrink: 0;
  margin-top: 80rpx;
}

.versus-text {
  font-size: 24rpx;
  font-weight: bold;
  color: #fff;
}

/* 速度选择 */
.speed-section {
  margin-bottom: 40rpx;
}

.speed-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.speed-options {
  display: flex;
  gap: 16rpx;
}

.speed-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 24rpx 16rpx;
  background-color: #f8f9fa;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.speed-option.active {
  background-color: #fff5e6;
  border-color: #8B4513;
  box-shadow: 0 4rpx 12rpx rgba(139, 69, 19, 0.15);
}

.speed-emoji {
  font-size: 40rpx;
}

.speed-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #333;
}

/* 开始按钮 */
.start-btn {
  width: 100%;
  padding: 32rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 12rpx;
  border: none;
}

.start-btn::after {
  border: none;
}

.start-btn[disabled] {
  opacity: 0.6;
}

/* 观战区域 */
.spectate-section {
  padding: 24rpx;
}

.match-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background-color: rgba(255, 255, 255, 0.95);
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.player-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.player-emoji {
  font-size: 32rpx;
}

.player-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
}

.red-player .player-name {
  color: #e74c3c;
}

.black-player .player-name {
  color: #2c3e50;
}

.match-score {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.score-label {
  font-size: 24rpx;
  color: #666;
}

.status-container {
  margin-bottom: 16rpx;
}

.board-container {
  background-color: rgba(255, 255, 255, 0.95);
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}

/* 控制按钮 */
.spectate-controls {
  display: flex;
  gap: 12rpx;
}

.control-btn {
  flex: 1;
  padding: 24rpx;
  background-color: rgba(255, 255, 255, 0.95);
  border-radius: 12rpx;
  font-size: 24rpx;
  border: none;
}

.control-btn.warning {
  background-color: #fff3cd;
  color: #856404;
}

.control-btn::after {
  border: none;
}

/* 思考指示器 */
.thinking-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 20rpx;
  background-color: rgba(255, 255, 255, 0.95);
  border-radius: 12rpx;
  margin-top: 16rpx;
}

.thinking-dots {
  display: flex;
  gap: 8rpx;
}

.dot {
  font-size: 24rpx;
  color: #667eea;
  animation: bounce 1.4s infinite ease-in-out both;
}

.dot:nth-child(1) {
  animation-delay: -0.32s;
}

.dot:nth-child(2) {
  animation-delay: -0.16s;
}

@keyframes bounce {
  0%, 80%, 100% {
    transform: scale(0);
  }
  40% {
    transform: scale(1);
  }
}

.thinking-text {
  font-size: 24rpx;
  color: #666;
}
