<!--控制面板组件-->
<view class="control-panel">
  <!-- 主控制按钮 -->
  <view class="main-controls">
    <view class="control-row">
      <button
        class="control-btn btn-undo"
        bindtap="handleUndo"
        disabled="{{gameStatus !== 'playing'}}"
      >
        <view class="btn-icon">↩</view>
        <view class="btn-text">悔棋</view>
      </button>

      <button
        class="control-btn btn-hint"
        bindtap="handleHint"
        disabled="{{gameStatus !== 'playing'}}"
      >
        <view class="btn-icon">?</view>
        <view class="btn-text">提示</view>
      </button>

      <button
        class="control-btn btn-restart"
        bindtap="handleRestart"
      >
        <view class="btn-icon">↻</view>
        <view class="btn-text">重开</view>
      </button>
    </view>
  </view>

  <!-- 次要控制按钮 -->
  <view class="secondary-controls" wx:if="{{showBack}}">
    <view class="control-row">
      <button
        class="control-btn btn-back"
        bindtap="handleBack"
      >
        <view class="btn-icon">←</view>
        <view class="btn-text">返回</view>
      </button>

      <button
        class="control-btn btn-settings"
        bindtap="handleSettings"
      >
        <view class="btn-icon">⚙</view>
        <view class="btn-text">设置</view>
      </button>

      <button
        class="control-btn btn-share"
        open-type="share"
      >
        <view class="btn-icon">⤴</view>
        <view class="btn-text">分享</view>
      </button>
    </view>
  </view>

  <!-- 游戏状态提示 -->
  <view class="status-hint" wx:if="{{gameStatus === 'playing'}}">
    <text class="hint-text">
      <text class="hint-red" wx:if="{{currentPlayer === 'red'}}">红方走棋</text>
      <text class="hint-black" wx:if="{{currentPlayer === 'black'}}">黑方思考中...</text>
    </text>
  </view>
</view>
