/* 控制面板组件样式 */

.control-panel {
  width: 100%;
  padding: 20rpx;
  box-sizing: border-box;
}

/* 主控制按钮 */
.main-controls {
  margin-bottom: 20rpx;
}

.control-row {
  display: flex;
  justify-content: center;
  gap: 20rpx;
}

.control-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 20rpx;
  border-radius: 16rpx;
  border: none;
  background: #fff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s;
  min-height: 120rpx;
}

.control-btn:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.control-btn:disabled {
  opacity: 0.5;
}

/* 按钮图标 */
.btn-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

/* 按钮文字 */
.btn-text {
  font-size: 24rpx;
  font-weight: 500;
  color: #333;
}

/* 悔棋按钮 */
.btn-undo {
  background: linear-gradient(135deg, #ffecd2 0%, #fcb69f 100%);
}

.btn-undo .btn-icon {
  color: #e65100;
}

/* 提示按钮 */
.btn-hint {
  background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%);
}

.btn-hint .btn-icon {
  color: #00796b;
}

/* 重开按钮 */
.btn-restart {
  background: linear-gradient(135deg, #ffd89b 0%, #19547b 100%);
}

.btn-restart .btn-icon {
  color: #fff;
}

/* 次要控制按钮 */
.secondary-controls {
  border-top: 1rpx solid #f0f0f0;
  padding-top: 20rpx;
}

.secondary-controls .control-btn {
  min-height: 100rpx;
  padding: 16rpx;
}

.secondary-controls .btn-icon {
  font-size: 36rpx;
  margin-bottom: 4rpx;
}

.secondary-controls .btn-text {
  font-size: 22rpx;
}

/* 返回按钮 */
.btn-back {
  background: #f5f5f5;
}

.btn-back .btn-icon {
  color: #666;
}

/* 设置按钮 */
.btn-settings {
  background: #f5f5f5;
}

.btn-settings .btn-icon {
  color: #666;
}

/* 分享按钮 */
.btn-share {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.btn-share .btn-text {
  color: #fff;
}

.btn-share .btn-icon {
  color: #fff;
}

/* 状态提示 */
.status-hint {
  text-align: center;
  padding: 20rpx;
  margin-top: 20rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 12rpx;
}

.hint-text {
  font-size: 28rpx;
  font-weight: bold;
}

.hint-red {
  color: #dc143c;
}

.hint-black {
  color: #333;
}
