<view class="game-status">
  <view class="status-row">
    <view class="turn-indicator">
      <view class="turn-dot {{turn === 'red' ? 'red-turn' : 'black-turn'}}"></view>
      <text class="turn-text">当前回合: {{turn === 'red' ? '红方' : '黑方'}}</text>
    </view>
  </view>

  <view class="status-row" wx:if="{{status !== 'playing'}}">
    <view class="game-end-badge {{status}}">
      <text class="game-end-text">{{statusText}}</text>
    </view>
  </view>

  <view class="status-row" wx:if="{{lastMove}}">
    <view class="last-move">
      <text class="last-move-label">最后一走:</text>
      <text class="last-move-coord">({{lastMove.from.x}}, {{lastMove.from.y}}) → ({{lastMove.to.x}}, {{lastMove.to.y}})</text>
    </view>
  </view>

  <view class="status-row" wx:if="{{moveCount > 0}}">
    <view class="move-count">
      <text class="move-count-text">总步数: {{moveCount}}</text>
    </view>
  </view>
</view>
