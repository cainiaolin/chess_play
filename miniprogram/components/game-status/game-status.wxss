.game-status {
  padding: 24rpx;
  background-color: #fff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.status-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
}

/* 回合指示器 */
.turn-indicator {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.turn-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  border: 3rpx solid #ddd;
  transition: all 0.3s ease;
}

.turn-dot.red-turn {
  background-color: #e74c3c;
  border-color: #c0392b;
  box-shadow: 0 0 12rpx rgba(231, 76, 60, 0.5);
}

.turn-dot.black-turn {
  background-color: #2c3e50;
  border-color: #1a252f;
  box-shadow: 0 0 12rpx rgba(44, 62, 80, 0.5);
}

.turn-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

/* 游戏结束徽章 */
.game-end-badge {
  padding: 16rpx 32rpx;
  border-radius: 50rpx;
  text-align: center;
}

.game-end-badge.red_win {
  background: linear-gradient(135deg, #e74c3c, #c0392b);
}

.game-end-badge.black_win {
  background: linear-gradient(135deg, #2c3e50, #1a252f);
}

.game-end-badge.draw {
  background: linear-gradient(135deg, #95a5a6, #7f8c8d);
}

.game-end-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}

/* 最后一走 */
.last-move {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.last-move-label {
  font-size: 24rpx;
  color: #888;
}

.last-move-coord {
  font-size: 26rpx;
  font-family: 'Courier New', monospace;
  color: #8B4513;
  font-weight: 600;
}

/* 步数统计 */
.move-count {
  display: flex;
  justify-content: center;
}

.move-count-text {
  font-size: 24rpx;
  color: #666;
  background-color: #f5f5f5;
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
}
