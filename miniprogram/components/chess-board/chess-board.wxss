/* 棋盘组件样式 */

.chess-board {
  width: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 20rpx;
  box-sizing: border-box;
}

.chess-canvas {
  background: #f0d9b5;
  border-radius: 8rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}
